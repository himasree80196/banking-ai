# App
APP_NAME="AI Smart Banking Assistant"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — SQLite for local dev (no Postgres needed)
DATABASE_URL=sqlite+aiosqlite:///./banking.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/banking_ai

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# LLM PROVIDER — set to: openai | anthropic | ollama | mock
# ─────────────────────────────────────────────
LLM_PROVIDER=openai

# OpenAI (recommended)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Ollama (free, local — install from https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
